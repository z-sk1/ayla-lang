import rl
import time

rl.InitAudio()

fun (s rl.Sound) Play(vol float) {
    rl.PlaySound(s)
    rl.SetSoundVolume(s, vol)

    why rl.IsSoundPlaying(s) {
        time.Sleep(0.1)
    }

    rl.StopSound(s)
}

s := rl.LoadSound("example.wav") // put your own file
s.Play(1)

rl.UnloadSound(s)

rl.CloseAudio()

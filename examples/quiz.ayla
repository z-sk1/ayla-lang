putln("1-12 times tables")

say score int
say total int

while yes {
    say num1, num2 = rand.Int(1, 12), rand.Int(1, 12)
    say ans = num1 * num2
    say choice int
    putln("${num1 * num2} = ? (q to quit)")
    scanln(&choice)
    ayla choice == "q" {
        putln("Final score: ${score / total}")
        kitkat
    }
    ayla choice == ans {
        putln("Correct!")
        score++
        total++
    } elen {
        putln("Incorrect! Correct is ${ans}")
        total++
    }
}